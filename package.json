{
  "name": "attajak.github.io",
  "version": "1.0.0",
  "description": "GitHub Pages",
  "private": "true",
  "scripts": {
    "jekyll": "bundle exec jekyll",
    "doctor": "bundle exec jekyll doctor",
    "prepare": "git submodule update --init --recursive && bundle install",
    "serve": "bundle exec jekyll serve --draft --future --unpublished --livereload --incremental --watch --profile --open_url --trace",
    "start": "npm run serve",
    "build": "bundle exec jekyll build",
    "update": "git submodule update --remote --merge && bundle update"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/attajak/attajak.github.io.git"
  },
  "keywords": [
    "attajak",
    "janrak",
    "github",
    "page",
    "pages",
    "jekyll",
    "package"
  ],
  "author": {
    "name": "attajak",
    "email": "janrak@gmail.com",
    "url": "https://github.com/attajak"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/attajak/attajak.github.io/issues"
  },
  "homepage": "https://github.com/attajak/attajak.github.io#readme"
}
